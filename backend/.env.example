# ── Stellar network ──────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Assets ───────────────────────────────────────────────────────
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_CODE=USDC

# ── Friendbot / explorer ─────────────────────────────────────────
FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_EXPERT_BASE_URL=https://stellar.expert/explorer/testnet

# ── Server ───────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Shared secret for admin-only endpoints (e.g. PATCH /api/lembaga/:id/verify).
# Sent by the caller as the `x-admin-token` header. Leave blank to disable
# those endpoints (they respond 503 rather than running open).
ADMIN_TOKEN=

# ── Demo script (testnet only — never commit real secrets) ───────
# Master issuer secret used by scripts/setup-demo.ts to mint demo USDC.
# Leave blank to let the script generate and fund a fresh issuer.
DEMO_ISSUER_SECRET=

# ── Soroban zakat escrow + x402 (PoC) ────────────────────────────
# Network label advertised in x402 payment requirements.
X402_NETWORK=stellar-testnet
# Live PoC contracts deployed on Stellar Testnet (see docs/soroban-escrow-poc.md).
# The IDR token is the Stellar Asset Contract for the asset IDR:<issuer>.
ZAKAT_ESCROW_CONTRACT_ID=CCXQRXVBV7TPQSUFVX2H3FE43JQRPIP4BRHPE257Y3UAGAOIE4AYURJ5
IDR_TOKEN_CONTRACT_ID=CBKXWC5GZHMAQQTGXOFFABXZITVL3OVW6Z2CIFXNWZOM6U5PYKDK3AQM
